@app.route('/api/all_drugs_for_exchange')
def api_all_drugs_for_exchange():
    db = get_db()
    # فقط داروخانه‌های تایید شده
    drugs = db.execute('''
        SELECT i.*, u.pharmacy_display_name, u.username, 
               CASE WHEN u.address LIKE '%تهران%' THEN 'تهران'
                    WHEN u.address LIKE '%اصفهان%' THEN 'اصفهان'
                    WHEN u.address LIKE '%شیراز%' THEN 'شیراز'
                    WHEN u.address LIKE '%کرمانشاه%' THEN 'کرمانشاه'
                    WHEN u.address LIKE '%کردستان%' THEN 'کردستان'
                    ELSE 'سایر' END as city,
               (strftime('%Y', i.created_at) * 12 + strftime('%m', i.created_at)) as expiry_value
        FROM inventory i
        JOIN users u ON i.user_id = u.id
        WHERE u.is_approved = 1 AND i.quantity > 0
        ORDER BY expiry_value ASC, i.created_at DESC
        LIMIT 200
    ''').fetchall()
    
    result = []
    for row in drugs:
        drug = dict(row)
        drug['is_new'] = is_new_item(row['created_at'])
        drug['pharmacy_code'] = str(row['user_id'])[:3] + '***'
        result.append(drug)
    return jsonify({'drugs': result})

