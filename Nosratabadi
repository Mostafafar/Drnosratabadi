    });
    
    function updateMonths(year) {
        let months = year === '2026' ? 
            [{name:'JUL',num:'07'},{name:'AUG',num:'08'},{name:'SEP',num:'09'},{name:'OCT',num:'10'},{name:'NOV',num:'11'},{name:'DEC',num:'12'}] :
            [{name:'JAN',num:'01'},{name:'FEB',num:'02'},{name:'MAR',num:'03'},{name:'APR',num:'04'},{name:'MAY',num:'05'},{name:'JUN',num:'06'}];
        let grid = document.getElementById('monthGrid');
        grid.innerHTML = '';
        months.forEach(m => {
            let btn = document.createElement('button');
            btn.className = 'month-btn';
            btn.dataset.month = m.num;
            btn.innerHTML = '<div class="month-name">' + m.name + '</div><div class="month-num">' + m.num + '</div>';
            grid.appendChild(btn);
        });
        document.getElementById('selectedDateText').textContent = 'هیچ';
        document.getElementById('expiryDate').value = '';
    }
    
    function updateMonthsSale(year) {
        let months = year === '2026' ? 
            [{name:'JUL',num:'07'},{name:'AUG',num:'08'},{name:'SEP',num:'09'},{name:'OCT',num:'10'},{name:'NOV',num:'11'},{name:'DEC',num:'12'}] :
            [{name:'JAN',num:'01'},{name:'FEB',num:'02'},{name:'MAR',num:'03'},{name:'APR',num:'04'},{name:'MAY',num:'05'},{name:'JUN',num:'06'}];
