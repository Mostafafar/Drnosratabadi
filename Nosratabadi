        fetch('/api/place_order', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({selected_ids:ids, company:company, quantities:qty}) }).then(()=>{ loadDrugs(); loadOrders(); });
    }
    
    document.getElementById('companyFilter').addEventListener('change', renderOrders);
    document.getElementById('searchFilter').addEventListener('input', renderOrders);
    loadDrugs();
    loadOrders();
    setInterval(loadOrders, 10000);
