@app.route('/chat')
@login_required
def chat():
    current_user = get_current_user_from_session()
    content = f'''
    <div class="chat-container">
        <div class="conversations-list" id="conversationsList">
            <div style="padding:20px;text-align:center">در حال بارگذاری...</div>
        </div>
        <div class="chat-area" id="chatArea" style="display:none">
            <div class="chat-header">
                <h3 id="chatPartnerName"></h3>
                <button class="btn-success btn-sm" id="exchangeRequestBtn" onclick="goToExchangeWithPartner()">🔄 درخواست تبادل</button>
            </div>
            <div class="chat-messages" id="chatMessages"></div>
            <div class="chat-input-area">
                <textarea id="messageInput" class="chat-input" placeholder="پیام خود را بنویسید..." rows="1"></textarea>
                <input type="file" id="imageInput" accept="image/*" style="display:none">
                <button class="chat-btn" onclick="document.getElementById('imageInput').click()">📷</button>
                <button class="chat-btn" id="voiceBtn">🎤</button>
                <button class="chat-btn" onclick="sendMessage()">📤</button>
            </div>
        </div>
    </div>
    
    <script>
        let currentPartnerId = null;
        let mediaRecorder = null;
        let audioChunks = [];
        let isRecording = false;
        
        function loadConversations() {{
            fetch('/api/get_conversations').then(r=>r.json()).then(data=>{{
                let html = '';
                if(data.conversations.length === 0) {{
                    html = '<div style="padding:20px;text-align:center;color:#999">هیچ گفتگویی وجود ندارد</div>';
                }} else {{
                    data.conversations.forEach(conv => {{
                        let activeClass = (currentPartnerId == conv.partner_id) ? 'active' : '';
                        html += `
                            <div class="conversation-item ${{activeClass}}" onclick="loadChat(${{conv.partner_id}}, '${conv.partner_name.replace(/'/g, "\\'")}')">
                                <div class="conversation-name">${{conv.partner_name}}</div>
                                <div class="conversation-last-msg">${{conv.last_message || 'بدون پیام'}}</div>
                                <div class="conversation-time">${{conv.last_time || ''}}</div>
                            </div>
                        `;
                    }});
                }}
                document.getElementById('conversationsList').innerHTML = html;
            }});
        }}
        
        function loadChat(partnerId, partnerName) {{
            currentPartnerId = partnerId;
            document.getElementById('chatPartnerName').innerText = partnerName;
            document.getElementById('chatArea').style.display = 'flex';
            document.getElementById('chatArea').style.flexDirection = 'column';
            
            fetch(`/api/get_chat_messages/${{partnerId}}`).then(r=>r.json()).then(data=>{{
                let html = '';
                data.messages.forEach(msg => {{
                    let isSent = (msg.sender_id == {session['user_id']});
                    html += `
                        <div class="message ${{isSent ? 'sent' : 'received'}}">
                            <div class="message-bubble">
                    `;
                    if(msg.message_type === 'text') {{
                        html += msg.message;
                    }} else if(msg.message_type === 'image') {{
                        html += `<img src="${{msg.file_url}}" class="message-img" onclick="window.open(this.src)">`;
                    }} else if(msg.message_type === 'voice') {{
                        html += `<audio controls class="message-audio" src="${{msg.file_url}}"></audio>`;
                    }}
                    html += `<div style="font-size:10px;margin-top:5px;opacity:0.7">${{new Date(msg.created_at).toLocaleTimeString('fa-IR')}}</div>`;
                    html += `</div></div>`;
                }});
                document.getElementById('chatMessages').innerHTML = html;
                document.getElementById('chatMessages').scrollTop = document.getElementById('chatMessages').scrollHeight;
            }});
            
            document.querySelectorAll('.conversation-item').forEach(item => {{
                item.classList.remove('active');
            }});
        }}
        
        function sendMessage() {{
            let message = document.getElementById('messageInput').value;
            if(!message.trim() && !pendingImage) return;
            
            let formData = new FormData();
            formData.append('receiver_id', currentPartnerId);
            formData.append('message', message);
            if(pendingImage) {{
                formData.append('image', pendingImage);
                pendingImage = null;
            }}
            
            fetch('/api/send_message', {{method: 'POST', body: formData}}).then(r=>r.json()).then(data=>{{
                if(data.success) {{
                    document.getElementById('messageInput').value = '';
                    loadChat(currentPartnerId, document.getElementById('chatPartnerName').innerText);
                    loadConversations();
                }} else {{
                    alert('خطا: ' + data.error);
                }}
            }});
        }}
        
        let pendingImage = null;
        document.getElementById('imageInput').addEventListener('change', function(e) {{
            if(e.target.files && e.target.files[0]) {{
                pendingImage = e.target.files[0];
                alert('عکس انتخاب شد. برای ارسال دکمه ارسال را بزنید.');
            }}
        }});
        
        // ضبط ویس
        document.getElementById('voiceBtn').addEventListener('click', async function() {{
            if(isRecording) {{
                mediaRecorder.stop();
                isRecording = false;
                this.style.backgroundColor = '';
                this.innerText = '🎤';
                return;
            }}
            try {{
                const stream = await navigator.mediaDevices.getUserMedia({{ audio: true }});
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                mediaRecorder.ondataavailable = event => {{
                    audioChunks.push(event.data);
                }};
                mediaRecorder.onstop = () => {{
                    const audioBlob = new Blob(audioChunks, {{ type: 'audio/webm' }});
                    const formData = new FormData();
                    formData.append('receiver_id', currentPartnerId);
                    formData.append('voice', audioBlob, 'voice.webm');
                    fetch('/api/send_voice', {{method: 'POST', body: formData}}).then(r=>r.json()).then(data=>{{
                        if(data.success) {{
                            loadChat(currentPartnerId, document.getElementById('chatPartnerName').innerText);
                            loadConversations();
                        }} else {{
                            alert('خطا در ارسال ویس');
                        }}
                    }});
                    stream.getTracks().forEach(track => track.stop());
                }};
                mediaRecorder.start();
                isRecording = true;
                this.style.backgroundColor = '#dc3545';
                this.innerText = '⏹️';
            }} catch(err) {{
                alert('دسترسی به میکروفون امکان‌پذیر نیست');
            }}
        }});
        
        function goToExchangeWithPartner() {{
            window.location.href = `/exchange_with_partner/${{currentPartnerId}}`;
        }}
        
        loadConversations();
        setInterval(() => {{
            if(currentPartnerId) loadChat(currentPartnerId, document.getElementById('chatPartnerName').innerText);
            loadConversations();
        }}, 5000);
    </script>
    '''
    return HTML.replace('<div id="dynamicContent"></div>', f'<div id="dynamicContent">{content}</div>')

