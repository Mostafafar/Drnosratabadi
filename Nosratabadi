    q = request.args.get('q', '')
    user_id = session['user_id']
    db = get_db()
    
    cursor = db.execute("""
        SELECT DISTINCT name FROM (
            SELECT name FROM inventory WHERE user_id = ?
            UNION
            SELECT name FROM drugs WHERE user_id = ?
        ) WHERE name LIKE ? LIMIT 10
    """, (user_id, user_id, f'%{q}%'))
    names = [row['name'] for row in cursor.fetchall()]
    
    result = []
    for name in names:
        warehouse_qty = 0
        pharmacy_qty = 0
        warehouse_baghmلی_qty = 0
        pharmacy_baghmلی_qty = 0
        
        for loc in ['warehouse', 'pharmacy', 'warehouse_baghmلی', 'pharmacy_baghmلی']:
            cursor = db.execute("SELECT SUM(quantity) as total FROM inventory WHERE user_id = ? AND name = ? AND location = ?", (user_id, name, loc))
            qty = cursor.fetchone()['total'] or 0
            if loc == 'warehouse':
                warehouse_qty = qty
            elif loc == 'pharmacy':
                pharmacy_qty = qty
            elif loc == 'warehouse_baghmلی':
                warehouse_baghmلی_qty = qty
            else:
                pharmacy_baghmلی_qty = qty
        
        cursor = db.execute("SELECT expiry_date FROM inventory WHERE user_id = ? AND name = ? AND expiry_date IS NOT NULL AND expiry_date != '' ORDER BY CASE WHEN expiry_date = '' THEN 1 ELSE 0 END, expiry_date ASC LIMIT 1", (user_id, name))
        nearest = cursor.fetchone()
        result.append({
            'name': name,
            'warehouse_qty': warehouse_qty,
            'pharmacy_qty': pharmacy_qty,
            'warehouse_baghmلی_qty': warehouse_baghmلی_qty,
            'pharmacy_baghmلی_qty': pharmacy_baghmلی_qty,
            'nearest_expiry': nearest['expiry_date'] if nearest else '-'
        })
    return jsonify(result)

@app.route('/api/get_inventory_grouped')
@login_required
def get_inventory_grouped():
    user_id = session['user_id']
    db = get_db()
    cursor = db.execute("SELECT DISTINCT name FROM inventory WHERE user_id = ?", (user_id,))
    names = [row['name'] for row in cursor.fetchall()]
    groups = []
    group_id = 1
    for name in names:
        cursor = db.execute("SELECT * FROM inventory WHERE user_id = ? AND name = ? ORDER BY CASE WHEN expiry_date IS NULL OR expiry_date = '' THEN 1 ELSE 0 END, expiry_date ASC", (user_id, name))
        items = [dict(row) for row in cursor.fetchall()]
        warehouse_qty = sum(i['quantity'] for i in items if i['location'] == 'warehouse')
        pharmacy_qty = sum(i['quantity'] for i in items if i['location'] == 'pharmacy')
        warehouse_baghmلی_qty = sum(i['quantity'] for i in items if i['location'] == 'warehouse_baghmلی')
        pharmacy_baghmلی_qty = sum(i['quantity'] for i in items if i['location'] == 'pharmacy_baghmلی')
        total_qty = warehouse_qty + pharmacy_qty + warehouse_baghmلی_qty + pharmacy_baghmلی_qty
        has_expiring = False
        for i in items:
            if i['expiry_date']:
                try:
                    p = i['expiry_date'].split('.')
                    if len(p) == 2:
                        exp = datetime(int(p[0]), int(p[1]), 1)
                        m = (exp.year - datetime.now().year) * 12 + (exp.month - datetime.now().month)
                        if 0 < m <= 3:
                            has_expiring = True
                            break
                except:
                    pass
        groups.append({
            'id': group_id,
            'name': name,
            'items': items,
            'warehouse_qty': warehouse_qty,
            'pharmacy_qty': pharmacy_qty,
            'warehouse_baghmلی_qty': warehouse_baghmلی_qty,
            'pharmacy_baghmلی_qty': pharmacy_baghmلی_qty,
            'total_qty': total_qty,
            'has_expiring': has_expiring
        })
        group_id += 1
    return jsonify({'groups': groups})

