                filterDrugs();
            });
        }
        
        function renderCities() {
            let cities = [...new Set(allDrugs.map(d => d.city || 'سایر'))];
            let html = '<div class="city-tab active" data-city="all" onclick="selectCity(\\'all\\')">همه شهرها</div>';
            cities.forEach(city => {
                html += `<div class="city-tab" data-city="${city}" onclick="selectCity('${city}')">${city}</div>`;
            });
            document.getElementById('cityTabs').innerHTML = html;
            
            let citySelect = '<option value="all">همه شهرها</option>';
            cities.forEach(city => {
                citySelect += `<option value="${city}">${city}</option>`;
            });
            document.getElementById('cityFilter').innerHTML = citySelect;
        }
        
        function selectCity(city) {
            document.querySelectorAll('.city-tab').forEach(tab => {
                tab.classList.remove('active');
                if(tab.dataset.city === city) tab.classList.add('active');
            });
            document.getElementById('cityFilter').value = city;
            filterDrugs();
