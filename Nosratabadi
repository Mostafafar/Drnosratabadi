                        <div class="expiry-group-content" id="group-${group.expiry_value}">
                            <div class="inventory-header">
                                <span><input type="checkbox" id="selectAll-${group.expiry_value}" onchange="toggleSelectAll(this, ${group.expiry_value})"></span>
                                <span>نام دارو</span>
                                <span>تاریخ انقضا</span>
                                <span>تعداد</span>
                                <span>مکان</span>
                                <span>عملیات</span>
                            </div>
                `;
                group.items.forEach(item => {
                    let isHidden = hiddenItemIds.has(item.id);
                    let statusClass = isExpired ? 'expired' : '';
                    html += `
                        <div class="inventory-row ${statusClass}" style="${isHidden ? 'opacity:0.4' : ''}">
                            <span><input type="checkbox" class="item-checkbox" data-id="${item.id}" data-group="${group.expiry_value}"></span>
                            <span><strong>${item.name}</strong></span>
                            <span>${item.expiry_date || '-'}</span>
                            <span>${item.quantity}</span>
                            <span>${item.location === 'warehouse' ? 'انبار' : 'داروخانه'}</span>
                            <span><button class="btn-danger btn-sm" onclick="deleteItem(${item.id})">🗑️</button> <button class="btn-warning btn-sm" onclick="hideItem(${item.id})">🙈</button></span>
                        </div>
                    `;
                });
                html += `</div></div>`;
            });
            document.getElementById('inventoryGroups').innerHTML = html;
        }
        
        function toggleGroup(expiryValue) {
            let el = document.getElementById(`group-${expiryValue}`);
            if(el) el.classList.toggle('show');
        }
        
        function toggleSelectAll(checkbox, expiryValue) {
            document.querySelectorAll(`.item-checkbox[data-group="${expiryValue}"]`).forEach(cb => cb.checked = checkbox.checked);
        }
        
        function hideCheckedItems() {
            document.querySelectorAll('.item-checkbox:checked').forEach(cb => {
                let id = parseInt(cb.dataset.id);
                hiddenItemIds.add(id);
            });
            saveHidden();
            renderInventory();
        }
        
        function hideItem(id) {
            hiddenItemIds.add(id);
            saveHidden();
            renderInventory();
        }
        
        function resetHiddenItems() {
            hiddenItemIds.clear();
            saveHidden();
            renderInventory();
        }
        
        function filterInventory() {
            currentFilter = document.getElementById('liveSearch').value.toLowerCase();
            renderInventory();
        }
        
        function sortByExpiry() { currentSort = 'expiry_asc'; renderInventory(); }
        function sortByExpiryDesc() { currentSort = 'expiry_desc'; renderInventory(); }
        
        function addInventory() {
            let fd = new FormData();
            fd.append('name', document.getElementById('invName').value);
            fd.append('quantity', document.getElementById('invQty').value);
            fd.append('expiry_date', document.getElementById('expiryDate').value);
            fd.append('location', document.getElementById('location').value);
            fetch('/api/add_inventory', {method:'POST', body:fd}).then(r=>r.json()).then(data=>{
                if(data.success) { alert('ثبت شد'); location.reload(); }
                else alert('خطا: ' + data.error);
            });
        }
        
        function registerSale() {
            fetch('/api/register_sale', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    drug_name: document.getElementById('saleDrugName').value,
                    quantity: parseInt(document.getElementById('saleQty').value),
                    expiry_date: document.getElementById('saleExpiry').value
                })
            }).then(r=>r.json()).then(data=>{
                if(data.success) { alert('فروش ثبت شد'); location.reload(); }
                else alert('خطا: ' + data.error);
            });
        }
        
        function deleteItem(id) {
            if(confirm('حذف شود؟')) {
                fetch('/api/delete_inventory/'+id, {method:'POST'}).then(()=>loadInventory());
            }
        }
        
        function exportToTelegram() {
            let selected = [];
            document.querySelectorAll('.item-checkbox:checked').forEach(cb => {
                let id = parseInt(cb.dataset.id);
                for(let group of inventoryData) {
                    let item = group.items.find(i => i.id === id);
                    if(item) { selected.push(item); break; }
                }
            });
            if(selected.length === 0) { alert('هیچ آیتمی انتخاب نشده'); return; }
            let text = "📦 گزارش انبار\\n";
            selected.forEach(item => {
                text += `${item.name} - ${item.quantity} عدد - ${item.expiry_date || 'نامشخص'} - ${item.location === 'warehouse' ? 'انبار' : 'داروخانه'}\\n`;
            });
            navigator.clipboard.writeText(text);
            alert('کپی شد');
        }
        
        loadInventory();
        setInterval(loadInventory, 30000);
    </script>
    <style>
        .expiry-group-content { display: none; }
        .expiry-group-content.show { display: block; }
    </style>
    '''
    return HTML.replace('<div id="dynamicContent"></div>', f'<div id="dynamicContent">{content}</div>')
