            });
        });
        
        document.getElementById('monthGrid').addEventListener('click', function(e) {
            let btn = e.target.closest('.month-btn');
            if(!btn) return;
            document.querySelectorAll('.month-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            let year = document.querySelector('.year-btn.active').dataset.year;
            let month = btn.dataset.month;
            let fullDate = year + '.' + month;
            document.getElementById('expiryDate').value = fullDate;
            document.getElementById('selectedDateText').textContent = fullDate;
        });
        
        document.querySelectorAll('.year-btn-sale').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.year-btn-sale').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                updateMonthsSale(this.dataset.year);
            });
        });
        
        document.getElementById('monthGridSale').addEventListener('click', function(e) {
            let btn = e.target.closest('.month-btn-sale');
            if(!btn) return;
            document.querySelectorAll('.month-btn-sale').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            let year = document.querySelector('.year-btn-sale.active').dataset.year;
            let month = btn.dataset.month;
            document.getElementById('saleExpiry').value = year + '.' + month;
        });
        
        document.querySelectorAll('.year-btn-move').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.year-btn-move').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                updateMonthsMove(this.dataset.year);
            });
        });
        
        document.getElementById('monthGridMove').addEventListener('click', function(e) {
            let btn = e.target.closest('.month-btn-move');
            if(!btn) return;
            document.querySelectorAll('.month-btn-move').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            let year = document.querySelector('.year-btn-move.active').dataset.year;
            let month = btn.dataset.month;
            document.getElementById('moveExpiry').value = year + '.' + month;
