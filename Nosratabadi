            });
        }
        
        function loadDrugs() {
            fetch('/api/get_all_drugs').then(r=>r.json()).then(d=>{
                allDrugs = d.drugs || [];
                renderDrugsList();
            });
        }
        
        function renderDrugsList() {
            if(allDrugs.length==0){
