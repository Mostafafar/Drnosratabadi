    <script>
        let currentChatUserId = null;
        let chatInterval = null;
        
        function loadUserInfo() {
            fetch('/api/get_current_user').then(r=>r.json()).then(data=>{
                document.getElementById('pharmacyDisplayName').innerText = data.pharmacy_display_name;
                document.getElementById('userInfo').innerHTML = '👤 ' + data.username + ' | ' + data.pharmacy_display_name;
                sessionStorage.setItem('userId', data.id);
                sessionStorage.setItem('pharmacyId', data.id);
            }).catch(err=>console.error('Error loading user:', err));
        }
        loadUserInfo();
        
        function openChat(pharmacyId, pharmacyName) {
            currentChatUserId = pharmacyId;
            document.getElementById('chatTargetName').innerText = pharmacyName;
            document.getElementById('chatModal').style.display = 'flex';
            loadChatMessages();
            if(chatInterval) clearInterval(chatInterval);
            chatInterval = setInterval(loadChatMessages, 5000);
        }
        
        function closeChat() {
            document.getElementById('chatModal').style.display = 'none';
            if(chatInterval) { clearInterval(chatInterval); chatInterval = null; }
            currentChatUserId = null;
        }
        
        function loadChatMessages() {
            if(!currentChatUserId) return;
            fetch('/api/get_messages?other_user_id=' + currentChatUserId)
                .then(r=>r.json())
                .then(data=>{
                    let container = document.getElementById('chatMessages');
                    let currentUserId = parseInt(sessionStorage.getItem('userId'));
                    let html = '';
                    data.messages.forEach(msg=>{
                        let isSent = msg.from_user_id === currentUserId;
                        html += '<div class="chat-message ' + (isSent ? 'sent' : 'received') + '>';
                        html += '<div class="message-bubble">';
                        if(msg.message_type === 'text') html += msg.content;
                        else if(msg.message_type === 'image') html += '<img src="' + msg.file_url + '" class="chat-image" onclick="window.open(this.src)">';
                        else if(msg.message_type === 'audio') html += '<audio controls class="chat-audio"><source src="' + msg.file_url + '"></audio>';
                        html += '</div>';
                        html += '<div class="message-time">' + new Date(msg.created_at).toLocaleTimeString('fa-IR') + '</div>';
                        html += '</div>';
                    });
                    container.innerHTML = html;
                    container.scrollTop = container.scrollHeight;
                });
        }
        
        function sendMessage() {
            let input = document.getElementById('chatInput');
            let text = input.value.trim();
            if(!text || !currentChatUserId) return;
            fetch('/api/send_message', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({to_user_id: currentChatUserId, message_type: 'text', content: text})
            }).then(()=>{
                input.value = '';
                loadChatMessages();
            });
        }
        
        function sendImage() {
            let file = document.getElementById('chatImageInput').files[0];
            if(!file || !currentChatUserId) return;
            let reader = new FileReader();
            reader.onload = function(e) {
                fetch('/api/send_message', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({to_user_id: currentChatUserId, message_type: 'image', content: e.target.result})
                }).then(()=>{
                    document.getElementById('chatImageInput').value = '';
                    loadChatMessages();
                });
            };
            reader.readAsDataURL(file);
        }
        
        function sendAudio() {
            let file = document.getElementById('chatAudioInput').files[0];
            if(!file || !currentChatUserId) return;
            let reader = new FileReader();
            reader.onload = function(e) {
                fetch('/api/send_message', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({to_user_id: currentChatUserId, message_type: 'audio', content: e.target.result})
                }).then(()=>{
                    document.getElementById('chatAudioInput').value = '';
                    loadChatMessages();
                });
            };
            reader.readAsDataURL(file);
