@login_required
def add_inventory():
    data = load_data()
    data['inventory'].append({
        'id': data.get('inventory_next_id', 1),
        'name': request.form['name'],
        'quantity': int(request.form['quantity']),
        'batch_number': request.form.get('batch_number', ''),
        'expiry_date': request.form['expiry_date'],
        'manufacturer': request.form.get('manufacturer', ''),
        'location': request.form.get('location', 'warehouse'),
        'created_at': datetime.now().isoformat()
    })
    data['inventory_next_id'] = data.get('inventory_next_id', 1) + 1
    save_data(data)
    return jsonify({'success': True})

@app.route('/api/delete_inventory/<int:item_id>', methods=['POST'])
@login_required
def delete_inventory(item_id):
    data = load_data()
    data['inventory'] = [i for i in data.get('inventory', []) if i['id'] != item_id]
    save_data(data)
    return jsonify({'success': True})

@app.route('/api/companies')
@login_required
def get_companies():
    return jsonify(load_data().get('companies', []))

