@app.route('/api/send_message', methods=['POST'])
@login_required
def send_message():
    db = get_db()
    from_user_id = session['user_id']
    data = request.get_json()
    to_user_id = data.get('to_user_id')
    message_type = data.get('message_type', 'text')
    content = data.get('content', '')
    
    file_url = None
    if message_type in ['image', 'audio'] and content.startswith('data:'):
        if message_type == 'image':
            ext = 'png'
            if 'image/jpeg' in content: ext = 'jpg'
            elif 'image/png' in content: ext = 'png'
            elif 'image/gif' in content: ext = 'gif'
        else:
            ext = 'webm'
            if 'audio/mpeg' in content: ext = 'mp3'
            elif 'audio/wav' in content: ext = 'wav'
            elif 'audio/ogg' in content: ext = 'ogg'
        
        content = re.sub('^data:audio/.+;base64,', '', content)
        content = re.sub('^data:image/.+;base64,', '', content)
        
        filename = f"{uuid.uuid4().hex}.{ext}"
        filepath = os.path.join(UPLOAD_FOLDER, filename)
        try:
            with open(filepath, 'wb') as f:
                f.write(base64.b64decode(content))
            file_url = f'/uploads/{filename}'
        except:
            file_url = None
    
    db.execute('''INSERT INTO chat_messages (from_user_id, to_user_id, message_type, content, file_url, created_at, is_read)
                  VALUES (?, ?, ?, ?, ?, ?, 0)''',
               (from_user_id, to_user_id, message_type, content if message_type == 'text' else '', file_url, datetime.now().isoformat()))
    db.commit()
    return jsonify({'success': True})

