    cursor = db.execute("SELECT item_id FROM hidden_items WHERE user_id = ?", (user_id,))
    hidden_ids = [row['item_id'] for row in cursor.fetchall()]
    
    cursor = db.execute("""
        SELECT id, pharmacy_display_name 
        FROM users 
        WHERE id != ?
    """, (user_id,))
