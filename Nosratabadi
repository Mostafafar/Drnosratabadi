            btn.style.fontSize = '10px';
            btn.style.border = '1px solid #ddd';
            btn.style.borderRadius = '6px';
            btn.style.background = 'white';
            btn.style.cursor = 'pointer';
            grid.appendChild(btn);
        });
        document.getElementById('saleExpiry').value = '';
    }
    
    function updateMonthsMove(year) {
        let months = year === '2026' ? 
            [{name:'JUL',num:'07'},{name:'AUG',num:'08'},{name:'SEP',num:'09'},{name:'OCT',num:'10'},{name:'NOV',num:'11'},{name:'DEC',num:'12'}] :
            [{name:'JAN',num:'01'},{name:'FEB',num:'02'},{name:'MAR',num:'03'},{name:'APR',num:'04'},{name:'MAY',num:'05'},{name:'JUN',num:'06'}];
        let grid = document.getElementById('monthGridMove');
        grid.innerHTML = '';
        months.forEach(m => {
            let btn = document.createElement('button');
            btn.className = 'month-btn-move';
            btn.dataset.month = m.num;
            btn.textContent = m.name;
            btn.style.padding = '6px 4px';
            btn.style.fontSize = '10px';
            btn.style.border = '1px solid #ddd';
            btn.style.borderRadius = '6px';
            btn.style.background = 'white';
            btn.style.cursor = 'pointer';
            grid.appendChild(btn);
        });
