        purchase_price = float(price_str) if price_str and price_str.strip() else 0.0
    except ValueError:
        purchase_price = 0.0
    
    cursor = db.execute("SELECT id, quantity FROM inventory WHERE user_id = ? AND name = ? AND expiry_date = ? AND location = ? AND batch_number = ? LIMIT 1",
                       (user_id, name, expiry_date, location, batch_number))
