@app.route('/admin/api/all_exchanges')
@admin_required
def admin_all_exchanges():
    db = get_db()
    exchanges = db.execute('''
        SELECT e.*, u.pharmacy_display_name as buyer_name 
        FROM exchanges e 
        JOIN users u ON e.user_id = u.id 
        ORDER BY e.exchange_date DESC LIMIT 200
    ''').fetchall()
    return jsonify({'exchanges': [dict(row) for row in exchanges]})

@app.route('/admin/api/all_chats')
@admin_required
def admin_all_chats():
    db = get_db()
    chats = db.execute('''
        SELECT c.*, 
            s.pharmacy_display_name as sender_name,
            r.pharmacy_display_name as receiver_name
        FROM chats c
        JOIN users s ON c.sender_id = s.id
        JOIN users r ON c.receiver_id = r.id
        ORDER BY c.created_at DESC LIMIT 200
    ''').fetchall()
    return jsonify({'messages': [dict(row) for row in chats]})

@app.route('/admin/api/check_notifications')
@admin_required
def admin_check_notifications():
    db = get_db()
    count = db.execute("SELECT COUNT(*) as count FROM admin_notifications WHERE is_read = 0").fetchone()['count']
    db.execute("UPDATE admin_notifications SET is_read = 1 WHERE is_read = 0")
    db.commit()
    return jsonify({'new_count': count})

