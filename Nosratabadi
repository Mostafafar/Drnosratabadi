        fetch('/api/get_orders').then(r=>r.json()).then(d=>{
            allOrders = d.orders || [];
            renderOrders();
        });
    }
    function renderOrders() {
        let company = document.getElementById('companyFilter').value;
        let search = document.getElementById('searchFilter').value.toLowerCase();
        let filtered = allOrders;
        if(company !== 'all') filtered = filtered.filter(o=>o.company===company);
        if(search) filtered = filtered.filter(o=>o.drug_name && o.drug_name.toLowerCase().includes(search));
        if(filtered.length===0){
            document.getElementById('list').innerHTML = '<p style="text-align:center;padding:30px;color:#999">هیچ سفارشی نیست</p>';
            return;
        }
        let html = '<table style="width:100%;border-collapse:collapse;font-size:13px"> <thead> <tr> <th style="padding:10px 8px;text-align:right">شرکت</th> <th style="padding:10px 8px;text-align:right">نام دارو</th> <th style="padding:10px 8px;text-align:right">تعداد</th> <th style="padding:10px 8px;text-align:right">تاریخ سفارش</th> </tr> </thead> <tbody>';
        filtered.forEach(o=>{
            let d = new Date(o.ordered_at);
            html += '<tr> <td style="padding:10px 8px">' + o.company + '</td> <td style="padding:10px 8px"><strong>' + o.drug_name + '</strong></td> <td style="padding:10px 8px">' + o.quantity + '</td> <td style="padding:10px 8px">' + d.toLocaleDateString('fa-IR') + '</td> </tr>';
        });
        html += '</tbody><tr>';
        document.getElementById('list').innerHTML = html;
    }
    function resetFilters() {
        document.getElementById('companyFilter').value = 'all';
        document.getElementById('searchFilter').value = '';
        renderOrders();
    }
    document.getElementById('companyFilter').addEventListener('change', renderOrders);
    document.getElementById('searchFilter').addEventListener('input', renderOrders);
    loadOrders();
    setInterval(loadOrders, 5000);
    </script>
    '''
    return HTML.replace('<div id="dynamicContent"></div>', f'<div class="header"><div class="page-title">🛒 سفارشات</div><div class="user-info"><span id="userInfo"></span><a href="/logout" class="logout-btn">🚪 خروج</a></div></div><div id="dynamicContent">{content}</div>')

