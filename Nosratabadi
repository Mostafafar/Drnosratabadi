@app.route('/inventory')
@login_required
def inventory():
    content = '''
    <div class="card">
        <div class="card-title">📦 ثبت فاکتور جدید</div>
        <div class="form-row">
            <input type="text" id="invName" placeholder="نام دارو" style="flex:2">
