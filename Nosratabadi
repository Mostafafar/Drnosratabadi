# ============== API ==============
@app.route('/api/get_drugs')
@login_required
def get_drugs():
    data = load_data()
    return jsonify({'drugs': [d for d in data.get('drugs', []) if not d.get('ordered', False)]})

@app.route('/api/get_all_drugs')
@login_required
def get_all_drugs():
    return jsonify({'drugs': load_data().get('drugs', [])})

@app.route('/api/add_drug', methods=['POST'])
@login_required
def add_drug():
    data = load_data()
    data['drugs'].append({
        'id': data['next_id'],
        'name': request.form['name'],
        'quantity': int(request.form['quantity']),
        'type': request.form['type'],
        'priority': int(request.form.get('priority', 4)),
        'created_at': datetime.now().isoformat(),
        'ordered': False
    })
    data['next_id'] += 1
    save_data(data)
    return jsonify({'success': True})

@app.route('/api/delete_drug/<int:drug_id>', methods=['POST'])
@login_required
def delete_drug(drug_id):
    data = load_data()
    data['drugs'] = [d for d in data['drugs'] if d['id'] != drug_id]
    save_data(data)
    return jsonify({'success': True})

@app.route('/api/place_order', methods=['POST'])
@login_required
def place_order():
    data = load_data()
    req = request.get_json()
    for drug in data['drugs']:
        if drug['id'] in req.get('selected_ids', []):
            data['orders'].append({
                'company': req.get('company'),
                'drug_name': drug['name'],
                'quantity': int(req.get('quantities', {}).get(str(drug['id']), drug['quantity'])),
                'ordered_at': datetime.now().isoformat()
            })
            if drug['type'] != 'quota':
                drug['ordered'] = True
    data['drugs'] = [d for d in data['drugs'] if d['type'] == 'quota' or not d.get('ordered', False)]
    save_data(data)
    return jsonify({'success': True})

