            html += '<input type="checkbox" class="exchange-drug-check" ' + (isSelected ? 'checked' : '') + ' onchange="event.stopPropagation(); toggleDrugSelection(\\'my\\', ' + drug.id + ', \\'' + safeName + '\\', ' + drug.quantity + ', \\'' + (drug.expiry_date || '') + '\\', ' + sessionStorage.getItem('userId') + ')">';
            html += '<div class="exchange-drug-info"><div class="exchange-drug-name">' + drug.name + '</div>';
