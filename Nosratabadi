def validate_expiry_date(date_str):
    if not date_str or date_str.strip() == '':
        return False
    pattern = r'^\d{4}\.[1-9]$|^\d{4}\.1[0-2]$'
    return re.match(pattern, date_str) is not None

def parse_expiry_date(expiry_str):
    if not expiry_str or expiry_str == '':
        return 999999
    try:
        if '.' in expiry_str:
            parts = expiry_str.split('.')
            year = int(parts[0])
            month = int(parts[1])
            return year * 12 + month
    except:
        return 999999
    return 999999

def get_persian_date():
    try:
        import jdatetime
        return jdatetime.datetime.now().strftime('%A %d %B')
    except:
        return datetime.now().strftime('%A %d %B')

def get_expiry_status(expiry_date):
    if not expiry_date:
        return {'text': 'نامشخص', 'class': ''}
    try:
        if '.' in expiry_date:
            parts = expiry_date.split('.')
            year = int(parts[0])
            month = int(parts[1])
        else:
            return {'text': 'نامعتبر', 'class': ''}
        now = datetime.now()
        exp = datetime(year, month, 1)
        months_left = (exp.year - now.year) * 12 + (exp.month - now.month)
        if months_left < 0:
            return {'text': 'منقضی', 'class': 'expired'}
        elif months_left <= 3:
            return {'text': f'{months_left} ماه مانده', 'class': 'expiring-soon'}
        else:
            return {'text': f'{months_left} ماه مانده', 'class': 'good-expiry'}
    except:
