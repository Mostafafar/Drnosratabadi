    <div class="card">
        <div class="card-title">📊 لیست انبار (تفکیک بر اساس تاریخ انقضا)</div>
        <div class="form-row">
            <input type="text" id="liveSearch" placeholder="🔍 جستجوی زنده..." onkeyup="filterInventory()" style="flex:2">
            <button onclick="sortByExpiry()">📅 مرتبسازی (نزدیک)</button>
            <button onclick="sortByExpiryDesc()">📅 مرتبسازی (دور)</button>
            <button onclick="hideCheckedItems()" class="btn-warning">🙈 هاید تیکخوردهها</button>
            <button onclick="resetHiddenItems()" class="btn-warning">🔄 ریست هاید</button>
            <button onclick="exportToTelegram()" class="btn-success">📱 کپی متن</button>
        </div>
        <div id="inventoryGroups"></div>
    </div>
    
    <script>
        let inventoryData = [];
        let currentSort = 'expiry_asc';
        let currentFilter = '';
        let hiddenItemIds = new Set();
        const HIDDEN_KEY = 'inv_hidden_' + sessionStorage.getItem('userId');
        
        function loadHidden() { let saved = localStorage.getItem(HIDDEN_KEY); if(saved) { try { hiddenItemIds = new Set(JSON.parse(saved)); } catch(e) {} } }
        function saveHidden() { localStorage.setItem(HIDDEN_KEY, JSON.stringify([...hiddenItemIds])); }
        loadHidden();
        
        function loadInventory() {
            fetch('/api/get_inventory_by_expiry').then(r=>r.json()).then(data=>{
                inventoryData = data.groups || [];
                renderInventory();
            });
        }
        
        function renderInventory() {
            let groups = [...inventoryData];
            if(currentFilter) groups = groups.filter(g => g.name.toLowerCase().includes(currentFilter));
            
            if(currentSort === 'expiry_asc') {
                groups.sort((a,b) => a.expiry_value - b.expiry_value);
            } else if(currentSort === 'expiry_desc') {
                groups.sort((a,b) => b.expiry_value - a.expiry_value);
            }
            
            if(groups.length === 0) {
                document.getElementById('inventoryGroups').innerHTML = '<p style="text-align:center;padding:30px;color:#999">انبار خالی است</p>';
                return;
            }
            
            let html = '';
            groups.forEach(group => {
                let isExpired = group.expiry_value && group.expiry_value < (new Date().getFullYear() * 12 + new Date().getMonth() + 1);
                let groupClass = isExpired ? 'expired' : '';
                let showClass = group.show ? 'show' : '';
                html += `
                    <div class="expiry-group">
                        <div class="expiry-group-header ${groupClass}" onclick="toggleGroup(${group.expiry_value})">
