        function filterDrugs() {
            let search = document.getElementById('searchInput').value.toLowerCase();
            let city = document.getElementById('cityFilter').value;
            let sort = document.getElementById('sortSelect').value;
            
            let filtered = allDrugs.filter(d => {
                if(city !== 'all' && d.city !== city) return false;
                if(search && !d.name.toLowerCase().includes(search) && !(d.pharmacy_name && d.pharmacy_name.toLowerCase().includes(search))) return false;
                return true;
            });
            
            if(sort === 'expiry_asc') filtered.sort((a,b) => (a.expiry_value || 999999) - (b.expiry_value || 999999));
            else if(sort === 'expiry_desc') filtered.sort((a,b) => (b.expiry_value || 0) - (a.expiry_value || 0));
            else if(sort === 'newest') filtered.sort((a,b) => new Date(b.created_at) - new Date(a.created_at));
            
            renderDrugsGrid(filtered);
        }
        
        function renderDrugsGrid(drugs) {
