    function togglePharmacy(pharmacyId) {
        let content = document.getElementById('pharmacy-content-' + pharmacyId);
        if(!content) return;
        if(content.classList.contains('show')) {
            content.classList.remove('show');
        } else {
            content.classList.add('show');
        }
    }
    
    function loadPharmacyDrugs(pharmacyId) {
        fetch('/api/get_pharmacy_drugs_grouped_for_exchange?pharmacy_id=' + pharmacyId)
            .then(r=>r.json())
            .then(data=>{
                if(data && data.groups) {
                    currentPharmacyDrugs[pharmacyId] = data.groups || [];
                } else {
                    currentPharmacyDrugs[pharmacyId] = [];
                }
                renderPharmacyDrugs(pharmacyId);
            })
            .catch(err=>{
                console.error('Error loading pharmacy drugs:', err);
                currentPharmacyDrugs[pharmacyId] = [];
                renderPharmacyDrugs(pharmacyId);
            });
    }
    
    function renderPharmacyDrugs(pharmacyId) {
        let container = document.getElementById('pharmacy-content-' + pharmacyId);
        if(!container) return;
        let groups = currentPharmacyDrugs[pharmacyId] || [];
        if(groups.length === 0) {
            container.innerHTML = '<div style="padding:20px;text-align:center;color:#999">هیچ دارویی موجود نیست</div>';
            container.classList.add('show');
            return;
        }
        let html = '';
        groups.forEach(group => {
            if(!group.items || group.items.length === 0) return;
            let groupStatus = getExpiryStatusText(group.expiry_date);
            html += '<div class="expiry-group">';
            html += '<div class="expiry-group-header" style="background:' + (groupStatus.class === 'expired' ? '#f8d7da' : (groupStatus.class === 'expiring-soon' ? '#fff3cd' : '#d4edda')) + '">';
            html += '<span>📅 ' + group.expiry_date + '</span>';
            html += '<span class="expiry-status ' + groupStatus.class + '">' + groupStatus.text + '</span>';
            html += '</div><div class="expiry-group-items">';
            group.items.forEach(drug => {
                let isSelected = selectedItems.some(item => item.pharmacy_id === pharmacyId && item.id === drug.id);
                html += '<div class="exchange-drug-item ' + (isSelected ? 'selected' : '') + '" onclick="toggleDrugSelection(' + pharmacyId + ', ' + drug.id + ', \'' + drug.name.replace(/'/g, "\\\\'") + '\', ' + drug.quantity + ', \'' + (drug.expiry_date || '') + '\')">';
                html += '<input type="checkbox" class="exchange-drug-check" ' + (isSelected ? 'checked' : '') + ' onchange="event.stopPropagation(); toggleDrugSelection(' + pharmacyId + ', ' + drug.id + ', \'' + drug.name.replace(/'/g, "\\\\'") + '\', ' + drug.quantity + ', \'' + (drug.expiry_date || '') + '\')">';
                html += '<div class="exchange-drug-info"><div class="exchange-drug-name">' + drug.name + '</div>';
                html += '<div class="exchange-drug-detail">📦 موجودی: ' + drug.quantity + ' عدد</div></div>';
                if(isSelected) {
                    let selectedItem = selectedItems.find(item => item.pharmacy_id === pharmacyId && item.id === drug.id);
                    let qty = selectedItem ? selectedItem.quantity : drug.quantity;
                    html += '<input type="number" class="exchange-qty-input" value="' + qty + '" min="1" max="' + drug.quantity + '" onchange="updateSelectedQuantity(' + pharmacyId + ', ' + drug.id + ', this.value)" onclick="event.stopPropagation()">';
                }
                html += '</div>';
            });
            html += '</div></div>';
        });
        container.innerHTML = html;
        container.classList.add('show');
    }
    
    function toggleDrugSelection(pharmacyId, drugId, name, maxQty, expiryDate) {
        let existingIndex = selectedItems.findIndex(item => item.pharmacy_id === pharmacyId && item.id === drugId);
        if(existingIndex !== -1) {
            selectedItems.splice(existingIndex, 1);
        } else {
            let pharmacy = allPharmacies.find(p => p.id === pharmacyId);
            selectedItems.push({
                pharmacy_id: pharmacyId,
                pharmacy_name: pharmacy ? pharmacy.name : '',
                id: drugId,
                name: name,
                quantity: maxQty,
                max_quantity: maxQty,
                expiry_date: expiryDate
            });
        }
        renderPharmacyDrugs(pharmacyId);
        renderSummary();
        
        if(selectedItems.length > 0) {
            document.getElementById('selectedDrugsContainer').style.display = 'block';
        } else {
            document.getElementById('selectedDrugsContainer').style.display = 'none';
        }
    }
    
    function updateSelectedQuantity(pharmacyId, drugId, newQuantity) {
        let item = selectedItems.find(item => item.pharmacy_id === pharmacyId && item.id === drugId);
        if(item) {
            let qty = parseInt(newQuantity);
            if(isNaN(qty)) qty = item.max_quantity;
            if(qty < 1) qty = 1;
            if(qty > item.max_quantity) qty = item.max_quantity;
            item.quantity = qty;
        }
        renderPharmacyDrugs(pharmacyId);
        renderSummary();
    }
    
    function renderSummary() {
        if(selectedItems.length === 0) {
            document.getElementById('summaryText').innerHTML = 'هیچ دارویی انتخاب نشده است';
            return;
        }
        let grouped = {};
        selectedItems.forEach(item => {
            if(!grouped[item.pharmacy_id]) {
                grouped[item.pharmacy_id] = {
                    name: item.pharmacy_name,
                    items: []
                };
            }
            grouped[item.pharmacy_id].items.push(item);
        });
        
        let html = '';
        for(let phId in grouped) {
            let ph = grouped[phId];
            html += '<div style="margin-bottom:15px;border-right:3px solid #1a1a1a;padding-right:10px">';
            html += '<strong>🏥 ' + ph.name + ':</strong><br>';
            ph.items.forEach(item => {
                html += '• ' + item.name + ' - ' + item.quantity + ' عدد (📅 ' + (item.expiry_date || 'نامشخص') + ')<br>';
            });
            html += '</div>';
        }
        document.getElementById('summaryText').innerHTML = html;
    }
    
    function resetExchangeSelection() {
        selectedItems = [];
        for(let phId in currentPharmacyDrugs) {
            renderPharmacyDrugs(parseInt(phId));
        }
        renderSummary();
        document.getElementById('selectedDrugsContainer').style.display = 'none';
