    function confirmExchangeFinal() {
        if(selectedItems.length === 0) {
            alert('هیچ دارویی برای تبادل انتخاب نشده است');
            return;
        }
        
        let groupedByPharmacy = {};
        selectedItems.forEach(item => {
            if(!groupedByPharmacy[item.pharmacy_id]) {
                groupedByPharmacy[item.pharmacy_id] = {
                    pharmacy_id: item.pharmacy_id,
                    pharmacy_name: item.pharmacy_name,
                    items: []
                };
            }
            groupedByPharmacy[item.pharmacy_id].items.push({
                id: item.id,
                name: item.name,
                quantity: item.quantity,
                expiry_date: item.expiry_date
            });
        });
        
        let summary = '';
        for(let phId in groupedByPharmacy) {
            let ph = groupedByPharmacy[phId];
            summary += `\\n🏥 ${ph.pharmacy_name}:\\n`;
            ph.items.forEach(i => summary += `  - ${i.name}: ${i.quantity} عدد\\n`);
        }
        
        if(!confirm(`آیا از ارسال درخواست تبادل اطمینان دارید؟\\n\\n${summary}\\nتوجه: شما فقط می‌توانید از داروهای خودتان برای تبادل بدهید. لطفاً ابتدا درخواست تبادل را ارسال کنید تا داروخانه هدف پاسخ دهد.`)) return;
        
        let promises = [];
        for(let phId in groupedByPharmacy) {
            let ph = groupedByPharmacy[phId];
            let data = {
                target_pharmacy_id: ph.pharmacy_id,
                requested_items: ph.items
            };
            promises.push(fetch('/api/request_exchange', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            }).then(r=>r.json()));
        }
        
        Promise.all(promises).then(results => {
            let allSuccess = results.every(r => r && r.success);
            if(allSuccess) {
                alert('✅ درخواست تبادل با موفقیت ارسال شد');
                resetExchangeSelection();
                loadExchanges();
                loadPendingExchanges();
            } else {
                alert('❌ خطا در ارسال برخی درخواست‌ها');
            }
        }).catch(err=>{
            console.error('Error in exchange request:', err);
            alert('❌ خطا در ارسال درخواست تبادل');
        });
    }
    
