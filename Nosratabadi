@app.route('/api/get_inventory_by_expiry')
@login_required
def api_get_inventory_by_expiry():
    user = get_current_user_from_session()
    db = get_db()
    items = db.execute('''
        SELECT id, name, quantity, expiry_date, location, created_at
        FROM inventory WHERE user_id = ? AND quantity > 0
    ''', (user['id'],)).fetchall()
    
    # گروه‌بندی بر اساس تاریخ انقضا
    groups_dict = {}
    for item in items:
        expiry = item['expiry_date'] or 'نامشخص'
        if expiry not in groups_dict:
            expiry_value = parse_expiry_date(expiry) if expiry != 'نامشخص' else 999999
            groups_dict[expiry] = {
                'expiry_date': expiry,
                'expiry_value': expiry_value,
                'total_qty': 0,
                'items': [],
                'show': False
            }
        groups_dict[expiry]['items'].append(dict(item))
        groups_dict[expiry]['total_qty'] += item['quantity']
    
    # مرتب‌سازی آیتم‌ها در هر گروه بر اساس نام
    for expiry in groups_dict:
        groups_dict[expiry]['items'].sort(key=lambda x: x['name'])
    
    groups = list(groups_dict.values())
    groups.sort(key=lambda x: x['expiry_value'])
    
    return jsonify({'groups': groups})

