        new_quantity = existing['quantity'] + quantity
        db.execute("UPDATE inventory SET quantity = ? WHERE id = ?", (new_quantity, existing['id']))
    else:
        db.execute('''INSERT INTO inventory (user_id, name, quantity, batch_number, expiry_date, manufacturer, location, created_at, invoice_number, supplier, purchase_price)
                      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)''',
                   (user_id, name, quantity, batch_number, expiry_date, '', location, datetime.now().isoformat(), invoice_number, supplier, purchase_price))
    db.commit()
    return jsonify({'success': True})

@app.route('/api/move_inventory', methods=['POST'])
@login_required
def move_inventory():
    db = get_db()
    user_id = session['user_id']
    req = request.get_json()
    name = req.get('name')
    quantity = req.get('quantity')
    from_location = req.get('from_location')
    to_location = req.get('to_location')
    expiry_date = req.get('expiry_date', '').strip()
    
    if not expiry_date:
        return jsonify({'success': False, 'error': 'تاریخ انقضا اجباری است'})
    
    cursor = db.execute("SELECT * FROM inventory WHERE user_id = ? AND name = ? AND location = ? AND expiry_date = ?", 
                       (user_id, name, from_location, expiry_date))
    sources = cursor.fetchall()
    total_available = sum(s['quantity'] for s in sources)
    if total_available < quantity:
        return jsonify({'success': False, 'error': f'موجودی ناکافی. فقط {total_available} عدد در مبدا با تاریخ انقضای {expiry_date} موجود است'})
    
    remaining = quantity
    for source in sources:
        if remaining <= 0:
            break
        take = min(source['quantity'], remaining)
        if take > 0:
            db.execute("UPDATE inventory SET quantity = quantity - ? WHERE id = ?", (take, source['id']))
            if source['quantity'] - take == 0:
                db.execute("DELETE FROM inventory WHERE id = ?", (source['id'],))
            
            cursor = db.execute("SELECT id FROM inventory WHERE user_id = ? AND name = ? AND expiry_date = ? AND location = ? AND batch_number = ? LIMIT 1",
                               (user_id, name, expiry_date, to_location, source['batch_number']))
            dest = cursor.fetchone()
            if dest:
                db.execute("UPDATE inventory SET quantity = quantity + ? WHERE id = ?", (take, dest['id']))
            else:
                db.execute('''INSERT INTO inventory (user_id, name, quantity, batch_number, expiry_date, manufacturer, location, created_at, invoice_number, supplier, purchase_price)
                              VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)''',
                           (user_id, name, take, source['batch_number'], expiry_date, source['manufacturer'], to_location, datetime.now().isoformat(), source['invoice_number'], source['supplier'], source['purchase_price']))
            remaining -= take
    db.commit()
    return jsonify({'success': True})

