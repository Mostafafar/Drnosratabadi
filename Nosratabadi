@app.route('/api/get_conversations')
@login_required
def api_get_conversations():
    user = get_current_user_from_session()
    db = get_db()
    
    # پیدا کردن همه کاربرانی که با آنها چت داشته
    conversations = db.execute('''
        SELECT DISTINCT 
            CASE WHEN sender_id = ? THEN receiver_id ELSE sender_id END as partner_id,
            u.pharmacy_display_name as partner_name,
            (SELECT message FROM chats c2 WHERE (c2.sender_id = ? AND c2.receiver_id = u.id) OR (c2.sender_id = u.id AND c2.receiver_id = ?) ORDER BY created_at DESC LIMIT 1) as last_message,
            (SELECT created_at FROM chats c2 WHERE (c2.sender_id = ? AND c2.receiver_id = u.id) OR (c2.sender_id = u.id AND c2.receiver_id = ?) ORDER BY created_at DESC LIMIT 1) as last_time
        FROM chats c
        JOIN users u ON (u.id = c.sender_id OR u.id = c.receiver_id)
        WHERE (c.sender_id = ? OR c.receiver_id = ?) AND u.id != ?
        GROUP BY partner_id
        ORDER BY last_time DESC
    ''', (user['id'], user['id'], user['id'], user['id'], user['id'], user['id'], user['id'], user['id'])).fetchall()
    
    result = []
    for conv in conversations:
        conv_dict = dict(conv)
        conv_dict['partner_id'] = conv['partner_id']
        conv_dict['partner_name'] = conv['partner_name']
        conv_dict['last_message'] = (conv['last_message'][:50] + '...') if conv['last_message'] and len(conv['last_message']) > 50 else conv['last_message']
        result.append(conv_dict)
    
    return jsonify({'conversations': result})

@app.route('/api/get_chat_messages/<int:partner_id>')
@login_required
def api_get_chat_messages(partner_id):
    user = get_current_user_from_session()
    db = get_db()
    messages = db.execute('''
        SELECT * FROM chats 
        WHERE (sender_id = ? AND receiver_id = ?) OR (sender_id = ? AND receiver_id = ?)
        ORDER BY created_at ASC LIMIT 200
    ''', (user['id'], partner_id, partner_id, user['id'])).fetchall()
    
    result = []
    for msg in messages:
        m = dict(msg)
        if m['file_url']:
            m['file_url'] = f"/uploads/chat/{m['file_url'].split('/')[-1]}"
        result.append(m)
    
    return jsonify({'messages': result})

@app.route('/api/send_message', methods=['POST'])
@login_required
def api_send_message():
    user = get_current_user_from_session()
    receiver_id = request.form.get('receiver_id')
    message = request.form.get('message', '')
    image = request.files.get('image')
    
    if not receiver_id:
        return jsonify({'success': False, 'error': 'دریافت کننده مشخص نشده'})
    
    file_url = None
    message_type = 'text'
    
    if image and allowed_file(image.filename):
        filename = f"{datetime.now().timestamp()}_{user['id']}_{receiver_id}_{secure_filename(image.filename)}"
        filepath = os.path.join(app.config['UPLOAD_FOLDER'], filename)
        image.save(filepath)
        file_url = f"/uploads/chat/{filename}"
        message_type = 'image'
        message = message or '📷 تصویر'
    
    db = get_db()
    db.execute('''
        INSERT INTO chats (sender_id, receiver_id, message, message_type, file_url, created_at, is_read)
        VALUES (?, ?, ?, ?, ?, ?, 0)
    ''', (user['id'], receiver_id, message, message_type, file_url, datetime.now().isoformat()))
    db.commit()
    
    return jsonify({'success': True})

