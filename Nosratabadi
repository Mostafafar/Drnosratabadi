@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        pharmacy_name = request.form.get('pharmacy_name', '').strip()
        password = request.form.get('password', '')
        password_confirm = request.form.get('password_confirm', '')
        phone = request.form.get('phone', '').strip()
        address = request.form.get('address', '').strip()
        
        errors = []
        if not pharmacy_name:
            errors.append('نام داروخانه الزامی است')
        if len(password) < 6:
            errors.append('رمز عبور باید حداقل 6 کاراکتر باشد')
        if password != password_confirm:
            errors.append('رمز عبور و تکرار آن مطابقت ندارند')
        if not phone:
            errors.append('شماره تلفن الزامی است')
        if not address:
            errors.append('آدرس الزامی است')
        
        if errors:
            return render_register_form(errors)
        
        db = get_db()
        cursor = db.execute("SELECT COUNT(*) as count FROM users WHERE username = ?", (pharmacy_name,))
        if cursor.fetchone()['count'] > 0:
            return render_register_form(['این نام داروخانه قبلاً ثبت شده است'])
        
        cursor = db.execute("SELECT COUNT(*) as count FROM users WHERE phone = ?", (phone,))
        if cursor.fetchone()['count'] > 0:
            return render_register_form(['این شماره تلفن قبلاً ثبت شده است'])
        
        db.execute("INSERT INTO users (username, password_hash, phone, address, is_full_user, is_approved, pharmacy_display_name, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
            (pharmacy_name, hash_password(password), phone, address, 0, 0, pharmacy_name, datetime.now().isoformat()))
        db.commit()
        
        # ارسال اعلان به ادمین
        db.execute("INSERT INTO admin_notifications (type, related_id, message, created_at) VALUES (?, ?, ?, ?)",
            ('new_pharmacy', pharmacy_name, f'داروخانه جدید "{pharmacy_name}" ثبت‌نام کرد و منتظر تایید است', datetime.now().isoformat()))
        db.commit()
        
        return '''<!DOCTYPE html><html dir="rtl"><head><meta charset="UTF-8"><title>ثبت‌نام</title><style>
            body{font-family:Tahoma;background:#f5f5f5;display:flex;justify-content:center;align-items:center;height:100vh}
            .box{background:white;padding:30px;border-radius:16px;text-align:center}
            .success{color:#28a745}
        </style></head><body>
        <div class="box"><h2 class="success">✅ درخواست شما ثبت شد</h2>
        <p>درخواست شما برای ادمین ارسال شد. پس از تایید میتوانید وارد شوید.</p>
        <a href="/login">بازگشت به صفحه ورود</a></div></body></html>'''
    
    return render_register_form()

